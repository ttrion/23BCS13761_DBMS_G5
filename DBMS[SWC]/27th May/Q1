WITH latest_date AS (
    SELECT MAX(event_time::date) AS max_dt
    FROM search_events
),

user_segments AS (
    SELECT
        a.user_id,
        CASE
            WHEN a.registration_date >= (
                SELECT max_dt - INTERVAL '30 day'
                FROM latest_date
            )
            THEN 'new'
            ELSE 'existing'
        END AS user_segment
    FROM accounts a
),

searches AS (
    SELECT
        se.user_id,
        se.search_id,
        se.event_time AS search_time
    FROM search_events se
    WHERE se.event_type = 'search'
),

successful_searches AS (
    SELECT DISTINCT
        s.search_id
    FROM searches s
    JOIN search_events c
        ON s.user_id = c.user_id
       AND c.event_type = 'click'
       AND c.event_time >= s.search_time
       AND c.event_time <= s.search_time + INTERVAL '30 second'
)

SELECT
    us.user_segment,
    COUNT(s.search_id) AS total_searches,
    COUNT(ss.search_id) AS successful_searches,
    ROUND(
        COUNT(ss.search_id)::numeric
        / COUNT(s.search_id),
        4
    ) AS success_rate
FROM searches s
JOIN user_segments us
    ON s.user_id = us.user_id
LEFT JOIN successful_searches ss
    ON s.search_id = ss.search_id
GROUP BY us.user_segment
ORDER BY us.user_segment;