SELECT user_id
FROM (
    SELECT
        user_id,
        created_at AS first_purchase,
        LEAD(created_at) OVER (
            PARTITION BY user_id
            ORDER BY created_at
        ) AS second_purchase
    FROM amazon_transactions
) t
WHERE second_purchase - first_purchase BETWEEN 1 AND 7
GROUP BY user_id
ORDER BY user_id;